{
  "name": "pinoox/devdb",
  "description": "Development-only JSON/SQLite database driver for Pinoox apps",
  "keywords": [
    "pinoox",
    "pinx",
    "devdb",
    "database",
    "local-development"
  ],
  "type": "library",
  "license": "MIT",
  "homepage": "https://www.pinoox.com/",
  "authors": [
    {
      "name": "Pinoox",
      "email": "dev@pinoox.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/database": "^12.0",
    "symfony/console": "^7.2"
  },
  "autoload": {
    "classmap": [
      "src/DevDatabase.php",
      "src/Compat",
      "src/Component/Database/Connections/DevDbConnection.php",
      "src/Component/Database/DevDB",
      "src/Terminal/DevDB"
    ]
  },
  "scripts": {
    "test": "pest",
    "test:unit": "pest tests/Unit",
    "test:feature": "pest tests/Feature",
    "test:compat": "pest tests/Compatibility",
    "check": [
      "@composer validate --strict",
      "@test",
      "@test:compat"
    ]
  },
  "require-dev": {
    "pestphp/pest": "^2.36",
    "nunomaduro/collision": "^8.5"
  },
  "suggest": {
    "pinoox/pincore": "Required by Pinoox apps to register and use the DevDB driver.",
    "ext-pdo_sqlite": "Enables the preferred SQLite-backed DevDB engine when available."
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "extra": {
    "branch-alias": {
      "dev-master": "1.0.x-dev",
      "dev-main": "1.0.x-dev"
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
